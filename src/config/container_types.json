{
  "version": "1.0",
  "description": "Organisational buyer types. Each defines the data source, scoring signals and buyer archetype.",
  "containers": [
    {
      "id": "care_home",
      "display_name": "Care home / nursing home",
      "category": "residential_care",
      "buyer_archetype": "care_sector_coordinator",
      "primary_data_source": "cqc",
      "secondary_data_sources": ["companies_house"],
      "companies_house_sic": ["87100", "87300"],
      "cqc_filters": {
        "service_types": ["Residential care", "Nursing care"],
        "allowed_ratings": ["Outstanding", "Good"],
        "min_capacity": 20
      },
      "scoring_signals": {
        "strong_positive": [
          "Rated Outstanding or Good by CQC",
          "Resident capacity 30 or more beds",
          "In-house activities programme mentioned",
          "Dedicated activities coordinator listed",
          "Dementia specialist or elderly care focus"
        ],
        "moderate_positive": [
          "Part of a small group 2 to 10 homes",
          "Private or self-funded residents",
          "Recently refurbished or newly opened"
        ],
        "negative": [
          "Rated Requires Improvement or Inadequate",
          "Capacity under 15 beds",
          "Local authority only funded"
        ],
        "disqualifying": [
          "Closed or deregistered",
          "Childrens home"
        ]
      }
    },
